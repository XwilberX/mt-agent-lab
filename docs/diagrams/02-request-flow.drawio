        <mxCell id="m1" value="1. POST /t/acme/ask {question, session_id}&#xa;   Authorization: Bearer &lt;jwt&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;fontSize=11;align=left;verticalAlign=bottom" edge="1" parent="1">
