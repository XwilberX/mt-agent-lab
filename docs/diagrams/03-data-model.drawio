        <mxCell id="minio_note" value="🔒 ACCESO DESDE DUCKDB&#xa;&#xa;Vistas pre-creadas por request, scoped al tenant:&#xa;  CREATE VIEW ordenes AS SELECT * FROM read_parquet(&apos;s3://mt-data/{tenant}/ordenes.parquet&apos;)&#xa;&#xa;_validate_sql() bloquea: read_parquet, read_csv, read_json, attach, copy, pragma, ../, multi-statement.&#xa;Las credenciales S3 vienen de Vault, scoped por tenant via policy (acceso solo a su prefix)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e6f4e0;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top" vertex="1" parent="1">
