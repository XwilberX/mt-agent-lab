# Postgres
DATABASE_URL=postgresql://lab:lab@localhost:5433/mt_agent_lab

# ─────────── LLM backend ───────────
# LLM_PROVIDER: "ollama" (default) o "openai" (para servidores OpenAI-compat puros
# como vLLM-metal). El runner selecciona el provider de PydanticAI en función de
# este valor; OLLAMA_BASE_URL y OLLAMA_MODEL se interpretan en ambos casos.

# ── Opción A: vLLM-metal (recomendado, 4x más rápido @ conc=10) ──
# Levantar vLLM con: bash scripts/start_vllm.sh
LLM_PROVIDER=openai
OLLAMA_BASE_URL=http://localhost:8001/v1
OLLAMA_MODEL=mlx-community/Mistral-Small-24B-Instruct-2501-4bit

# ── Opción B: Ollama (más simple, degrada bajo concurrencia >1) ──
#LLM_PROVIDER=ollama
#OLLAMA_BASE_URL=http://localhost:11434/v1
#OLLAMA_MODEL=mistral-small:24b

# Filesystem
DATA_ROOT=./data/parquet

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
